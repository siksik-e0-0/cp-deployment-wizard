## TOKEN 포트 분리 필요

---
all:
  vars:
    ansible_connection: ssh
    ansible_user: 1726_admin1
    ansible_python_interpreter: /usr/bin/python3.11
    ansible_become: true
    ansible_port: 22
    ansible_strategy: parallel
      #deployment_strategy: rolling
    deployment_strategy: parallel
    confluent_package_version: "8.1.2"
    confluent_control_center_next_gen_package_version: "2.5.0"
    confluent_cli_archive_file_remote: false
    confluent_cli_download_enabled: false
    confluent_cli_path: /app/sol/kafka/confluent/confluent-8.1.2/bin/confluent

    ### JVM installation ###
    install_java: false
    custom_java_path: /usr/lib/jvm/java-17-openjdk
    sasl_protocol: plain
    kafka_controller_sasl_protocol: plain
    kafka_broker_sasl_protocol: plain
    sasl_plain_users:
      admin:
        principal: admin
        password: admin-secret

    installation_method: archive
    confluent_archive_file_source: /home/1726_admin1/docs/install/confluent_install/3.confluent/confluent-8.1.2.zip
    confluent_archive_file_remote: false
    archive_destination_path: /app/sol/kafka/confluent
    archive_owner: 1726_admin1
    archive_group: 1726_admin1

    kafka_broker_service_user: 1726_admin1
    kafka_broker_service_group: 1726_admin1
    kafka_controller_user: 1726_admin1
    kafka_controller_group: 1726_admin1
    kafka_broker_user: 1726_admin1
    kafka_broker_group: 1726_admin1
    control_center_next_gen_user: 1726_admin1
    control_center_next_gen_group: 1726_admin1
    schema_registry_user: 1726_admin1
    schema_registry_group: 1726_admin1
    
    kafka_controller_log_dir: /log/sol/kafka/confluent/controller
    kafka_broker_log_dir: /log/sol/kafka/confluent/broker
    control_center_next_gen_log_dir: /log/sol/kafka/confluent/c3
    schema_registry_log_dir: /log/sol/kafka/confluent/schema-registry

    confluent_archive_control_center_next_gen_file_remote: false
    confluent_archive_control_center_next_gen_file_source: /home/1726_admin1/docs/install/confluent_install/3.confluent/confluent-control-center-next-gen-2.5.0.tar.gz
    
    # Secret
    secrets_protection_enabled: true
      #ecrets_protection_masterkey: "6nSQpIV1sD8aOdqpV/z02aEAssCvrbo+GdL6lIrvHUQ="
      #ecrets_protection_security_file: "/app/sol/kafka/confluent/etc/secret/security.properties"
    regenerate_masterkey: true



    # C3 config
    control_center_next_gen_authentication_type: ldap
    control_center_next_gen_dependency_prometheus_basic_auth_enabled: false
    control_center_next_gen_dependency_alertmanager_basic_auth_enabled: false
    control_center_next_gen_data_dir: /data01/sol/kafka/confluent/c3
    control_center_next_gen_dependency_prometheus_port: 9090
    control_center_next_gen_dependency_alertmanager_port: 9098
    control_center_next_gen_streams_kafka_listener_name: internal
    control_center_next_gen_monitoring_interceptor_kafka_listener_name: internal
    control_center_next_gen_dependencies_config_path: /app/sol/kafka/confluent/confluent-control-center-next-gen-2.5.0/etc/confluent-control-center
    control_center_next_gen_ssl_enabled: true
    ssl_file_dir: /app/sol/kafka/confluent/etc/ssl
    c3_ssl_keystore_password: "ea14b428e8abde0e00b69584721d3c1b"
    c3_ssl_key_password: "ea14b428e8abde0e00b69584721d3c1b"
    c3_ssl_truststore_password: "ea14b428e8abde0e00b69584721d3c1b"
    #keystore_expiration_days: 365

    # Service accounts used by CP components
    c3_service_user: c3svc
    c3_service_password: changeit
    sr_service_user: srsvc
    sr_service_password: changeit

    # RBAC / MDS admin identity (used by automation and role binding tasks)
    rbac_enabled: true
    # control node path(if empty, generated auto)
    token_services_public_pem_file: /home/1726_admin1/.ansible_8.1.2/ansible_collections/confluent/platform/playbooks/generated_ssl_files/public.pem
    token_services_private_pem_file: /home/1726_admin1/.ansible_8.1.2/ansible_collections/confluent/platform/playbooks/generated_ssl_files/tokenKeypair.pem
    # install node path(copy mds key file to install node)
    rbac_enabled_public_pem_path: /app/sol/kafka/confluent/etc/public.pem
    rbac_enabled_private_pem_path: /app/sol/kafka/confluent/etc/tokenKeypair.pem

    mds_super_user: akadmin
    mds_super_user_password: changeit
    rbac_super_users:
      - "User:akadmin"
      #control_center_next_gen_additional_system_admins:
      #  - Group:c3-admins

    # LDAP bind account and directory lookup scope (for MDS/RBAC user/group resolution)
    mds_ldap_user: "cn=akadmin,ou=users,dc=ldap,dc=goauthentik,dc=io"
    mds_ldap_password: changeit
    ldap_url: "ldap://kiju-cp-test-4.fgcp-integration.com:389"
    ldap_base_dn: "dc=ldap,dc=goauthentik,dc=io"
    ldap_user_search_base: "ou=users,dc=ldap,dc=goauthentik,dc=io"
    ldap_group_search_base: "ou=groups,dc=ldap,dc=goauthentik,dc=io"
    ldap_user_name_attribute: "cn"
    ldap_user_object_class: "inetOrgPerson"
    ldap_group_object_class: "groupOfUniqueNames"
    ldap_group_member_attribute: "uniqueMember"
    ldap_group_name_attribute: "cn"


    schema_registry_listener_port: 9081
    schema_registry_config_prefix: "/etc/schema-registry"

    confluent_license: ""        
    jmxexporter_enabled: true
    jmxexporter_url_remote: false
      #kafka_broker_jmxexporter_enabled: false
      #kafka_controller_jmxexporter_enabled: false
    schema_registry_jmxexporter_enabled: false
    jmxexporter_jar_url: "/home/1726_admin1/docs/install/confluent_install/3.confluent/etc/jmx_prometheus_javaagent-0.20.0.jar"
    jmxexporter_jar_path: "/app/sol/kafka/confluent/etc/jmx_prometheus_javaagent-0.20.0.jar"
    kafka_controller_jmxexporter_config_path: /app/sol/kafka/confluent/etc/client.yml
    kafka_controller_jmxexporter_config_source_path: /home/1726_admin1/docs/install/confluent_install/3.confluent/etc/client.yml 
    kafka_controller_jmxexporter_port: 9995
    kafka_broker_jmxexporter_config_path: /app/sol/kafka/confluent/etc/client.yml
    kafka_broker_jmxexporter_config_source_path: /home/1726_admin1/docs/install/confluent_install/3.confluent/etc/client.yml
    kafka_broker_jmxexporter_port: 9999
    enable_node_id: false



    kafka_controller_custom_properties:
      metric.reporters: io.confluent.telemetry.reporter.TelemetryReporter
      confluent.telemetry.metrics.collector.interval.ms: 60000
      confluent.telemetry.remoteconfig._confluent.enabled: false
      confluent.consumer.lag.emitter.enabled: true
      confluent.metadata.security.protocol: SASL_PLAINTEXT
      confluent.metadata.sasl.mechanism: PLAIN
      confluent.metadata.sasl.jaas.config: org.apache.kafka.common.security.plain.PlainLoginModule required username="admin" password="admin-secret";

      confluent.balancer.enable: true
      
      num.network.threads: 3
      num.io.threads: 8
      num.partitions: 1
      num.recovery.threads.per.data.dir: 1
      
      socket.send.buffer.bytes: 102400
      socket.receive.buffer.bytes: 102400
      socket.request.max.bytes: 104857600
      
      log.retention.hours: 24
      log.segment.bytes: 1073741824
      log.retention.check.interval.ms: 300000
      log.dirs: /data01/sol/kafka/confluent/controller
      
      confluent.license: "{{ confluent_license }}"
      
      # Enable ACLs
      #authorizer.class.name: org.apache.kafka.metadata.authorizer.StandardAuthorizer
      #super.users: User:admin;User:ANONYMOUS 
      
      #sasl.enabled.mechanisms: PLAIN
      #sasl.mechanism.controller.protocol: PLAIN
      #sasl.mechanism.inter.broker.protocol: PLAIN
      #listener.name.sasl_plaintext.plain.sasl.jaas.config: org.apache.kafka.common.security.plain.PlainLoginModule required username="confluent" password="confluent" user_confluent="confluent" user_admin="admin";      

    kafka_broker_custom_properties:
      #metric.reporters: io.confluent.telemetry.reporter.TelemetryReporter
      confluent.telemetry.metrics.collector.interval.ms: 60000
      confluent.telemetry.remoteconfig._confluent.enabled: false
      confluent.consumer.lag.emitter.enabled: true
      
      num.network.threads: 16
      num.io.threads: 32
      num.partitions: 1
      num.recovery.threads.per.data.dir: 16 #default: 4
      
      socket.send.buffer.bytes: 2097152 #default: 102400
      socket.receive.buffer.bytes: 2097152 #default: 102400
      socket.request.max.bytes: 536870912
      num.replica.fetchers: 8 #default: 1
      replica.fetch.max.bytes: 10485760 #default: 1048576
      replica.fetch.response.max.bytes: 52428800 #default: 10485760
      
      log.retention.hours: 24
      log.segment.bytes: 1073741824
      log.retention.check.interval.ms: 300000
      log.dirs: /data01/sol/kafka/confluent/broker
      
      confluent.balancer.enable: "true"
      confluent.balancer.heal.uneven.load.trigger: "EMPTY_BROKER"
      confluent.balancer.heal.broker.failure.threshold.ms: 60000 
      auto.create.topics.enable: true
      delete.topic.enable: true
      default.replication.factor: 3
      unclean.leader.election.enable: false
      confluent.license.topic.replication.factor: 3
      
      min.insync.replicas: 2
      confluent.balancer.topic.replication.factor: 3
      confluent.durability.topic.replication.factor: 3
      confluent.tier.metadata.replication.factor: 3
      transaction.state.log.replication.factor: 3
      transaction.state.log.min.isr: 2
      offsets.topic.replication.factor: 3
      confluent.metadata.topic.replication.factor: 3
      confluent.reporters.telemetry.auto.enabled: false
      
      confluent.license: "{{ confluent_license }}"
      
      #ssl.client.auth: required
      #ssl.truststore.location: /ssl/kafka.server.truststore.jks
      #ssl.truststore.password: "!vbcjwps1!"
      #ssl.keystore.location: /ssl/kafka.server.keystore.jks
      #ssl.keystore.password: "!vbcjwps1!"
      #ssl.key.password: "!vbcjwps1!"

      # Enable ACLs
      #authorizer.class.name: org.apache.kafka.metadata.authorizer.StandardAuthorizer
      #super.users: User:confluent;User:ANONYMOUS
      
      #sasl.enabled.mechanisms: PLAIN
      #sasl.mechanism.controller.protocol: PLAIN
      #sasl.mechanism.inter.broker.protocol: PLAIN
      #listener.name.sasl_plaintext.plain.sasl.jaas.config: org.apache.kafka.common.security.plain.PlainLoginModule required username="confluent" password="confluent" user_confluent="confluent" user_admin="admin";
      
      # secret setting
      config.providers: securepass
      config.providers.securepass.class: io.confluent.kafka.security.config.provider.SecurePassConfigProvider
      
      #listener.name.client.sasl.enabled.mechanisms: PLAIN
      #listener.name.client.plain.sasl.jaas.config: org.apache.kafka.common.security.plain.PlainLoginModule required;
      #listener.name.client.plain.sasl.server.callback.handler.class: me.jhwang.MyCustomCallbackHandler
      confluent.metrics.reporter.publish.ms: 30000
      ldap.java.naming.factory.initial: com.sun.jndi.ldap.LdapCtxFactory
      ldap.com.sun.jndi.ldap.read.timeout: 3000
      ldap.java.naming.provider.url: "ldap://kiju-cp-test-4.fgcp-integration.com:389"
      ldap.java.naming.security.principal: "{{ mds_ldap_user }}"
      ldap.java.naming.security.credentials: "{{ mds_ldap_password }}"
      ldap.java.naming.security.authentication: simple
      ldap.user.search.base: "ou=users,dc=ldap,dc=goauthentik,dc=io"
      ldap.group.search.base: "ou=groups,dc=ldap,dc=goauthentik,dc=io"
      ldap.user.name.attribute: cn
      ldap.user.object.class: inetOrgPerson
      ldap.user.memberof.attribute.pattern: "(?i)cn=(.*),ou=groups,dc=ldap,dc=goauthentik,dc=io"
      ldap.group.name.attribute: cn
      ldap.group.member.attribute.pattern: "(?i)cn=(.*),ou=users,dc=ldap,dc=goauthentik,dc=io"
      
    schema_registry_custom_properties:
      confluent.license: "{{ confluent_license }}"
      # Schema Registry -> Kafka broker (for _schemas topic I/O)
      kafkastore.security.protocol: SASL_PLAINTEXT
      kafkastore.sasl.mechanism: OAUTHBEARER
      kafkastore.sasl.login.callback.handler.class: io.confluent.kafka.clients.plugins.auth.token.TokenUserLoginCallbackHandler
      kafkastore.sasl.jaas.config: >
        org.apache.kafka.common.security.oauthbearer.OAuthBearerLoginModule required
        metadataServerUrls="http://kiju-cp-test-1.fgcp-integration.com:8090,http://kiju-cp-test-2.fgcp-integration.com:8090,http://kiju-cp-test-3.fgcp-integration.com:8090"
        username="{{ sr_service_user }}"
        password="{{ sr_service_password }}";

      # Schema Registry security plugin / RBAC mode
      schema.registry.resource.extension.class: io.confluent.kafka.schemaregistry.security.SchemaRegistrySecurityResourceExtension
      confluent.schema.registry.auth.mechanism: JETTY_AUTH

      # Schema Registry -> MDS (RBAC metadata and token flow)
      confluent.metadata.bootstrap.server.urls: "http://kiju-cp-test-1.fgcp-integration.com:8090,http://kiju-cp-test-2.fgcp-integration.com:8090,http://kiju-cp-test-3.fgcp-integration.com:8090"
      confluent.metadata.http.auth.credentials.provider: BASIC
      confluent.metadata.basic.auth.user.info: "{{ sr_service_user }}:{{ sr_service_password }}"
      confluent.schema.registry.authorizer.class: io.confluent.kafka.schemaregistry.security.authorizer.rbac.RbacAuthorizer


    kafka_controller_service_environment_overrides:
      JAVA_HOME: /usr/lib/jvm/java-17-openjdk
      KAFKA_HEAP_OPTS: "-Xms4g -Xmx4g"
      #KAFKA_LOG4J_OPTS: "-Dlog4j.configuration=file:/app/sol/kafka/confluent/etc/log4j2.yaml"
      #KAFKA_JVM_PERFORMANCE_OPTS: "-server -XX:MetaspaceSize=256m -XX:+UseG1GC -XX:MaxGCPauseMillis=20 -XX:InitiatingHeapOccupancyPercent=35 -XX:G1HeapRegionSize=16M -XX:MinMetaspaceFreeRatio=50 -XX:MaxMetaspaceFreeRatio=80 -Djava.awt.headless -Djava.net.preferIPv4Stack=true"
      #KAFKA_JMX_OPTS: "-javaagent:/app/sol/kafka/confluent/etc/jmx_prometheus_javaagent-0.20.0.jar=9999:/app/sol/kafka/confluent/etc/client.yml -Dcom.sun.management.jmxremote.authenticate=false"
      #KAFKA_JMX_OPTS: "-Djava.rmi.server.hostname=127.0.0.1 -Dcom.sun.management.jmxremote=true -Dcom.sun.management.jmxremote.port=9999 -Dcom.sun.management.jmxremote.authenticate=false  -Dcom.sun.management.jmxremote.ssl=false"

    kafka_broker_service_environment_overrides:
      JAVA_HOME: /usr/lib/jvm/java-17-openjdk
      KAFKA_HEAP_OPTS: "-Xms4g -Xmx4g"
      #KAFKA_LOG4J_OPTS: "-Dlog4j.configuration=file:/app/sol/kafka/confluent/etc/log4j2.yaml"
      #KAFKA_JVM_PERFORMANCE_OPTS: "-server -XX:MetaspaceSize=256m -XX:+UseG1GC -XX:MaxGCPauseMillis=20 -XX:InitiatingHeapOccupancyPercent=35 -XX:G1HeapRegionSize=16M -XX:MinMetaspaceFreeRatio=50 -XX:MaxMetaspaceFreeRatio=80 -Djava.awt.headless -Djava.net.preferIPv4Stack=true"
      #KAFKA_JMX_OPTS: "-javaagent:/app/sol/kafka/confluent/etc/jmx_prometheus_javaagent-0.20.0.jar=9995:/app/sol/kafka/confluent/etc/client.yml -Dcom.sun.management.jmxremote.authenticate=false"
      #KAFKA_JMX_OPTS: "-javaagent:/app/sol/kafka/confluent/etc/jmx_prometheus_javaagent-0.20.0.jar=9999:/app/sol/kafka/confluent/etc/kafka_broker.yml -Dcom.sun.management.jmxremote.authenticate=false -Djava.rmi.server.hostname={{ broker_ip }} -Dcom.sun.management.jmxremote=true -Dcom.sun.management.jmxremote.port=9995 -Dcom.sun.management.jmxremote.ssl=false"

    control_center_next_gen_service_environment_overrides:
      JAVA_HOME: /usr/lib/jvm/java-17-openjdk
      CONTROL_CENTER_HEAP_OPTS: "-Xms2g -Xmx2g"
      #CONTROL_CENTER_OPTS: "-Djavax.net.ssl.trustStore={{ c3_ssl_truststore_path }} -Djavax.net.ssl.trustStorePassword={{ c3_ssl_truststore_password }}"
      #CONTROL_CENTER_LOG4J_OPTS: "-Dlog4j.configuration=file://"
      #CONTROL_CENTER_JVM_PERFORMANCE_OPTS: "-server -XX:+UseConcMarkSweepGC -XX:+CMSParallelRemarkEnabled -XX:ConcGCThreads=4 -XX:ParallelGCThreads=4 -XX:+CMSScavengeBeforeRemark"
      #CONTROL_CENTER_JVM_PERFORMANCE_OPTS: "-server -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:G1HeapRegionSize=8M -XX:InitiatingHeapOccupancyPercent=75 -XX:ConcGCThreads=4 -XX:ParallelGCThreads=4 -XX:+G1UseAdaptiveIHOP"
      #CONTROL_CENTER_JVM_PERFORMANCE_OPTS: "-server -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+UseStringDeduplication -XX:G1HeapRegionSize=16m -XX:InitiatingHeapOccupancyPercent=35 -XX:ConcGCThreads=4 -XX:ParallelGCThreads=8"
      #CONTROL_CENTER_OPTS: "-Djava.security.auth.login.config=/app/sol/kafka/confluent/etc/c3_jaas.config"
      #CONFLUENT_SECURITY_MASTER_KEY: "6nSQpIV1sD8aOdqpV/z02aEAssCvrbo+GdL6lIrvHUQ="
      
    control_center_next_gen_dependency_prometheus_service_environment_overrides:  
      User: 1726_admin1
      Group: 1726_admin1
      PROMETHEUS_HOST: kiju-cp-test-4.fgcp-integration.com
      PROMETHEUS_PORT: 9090
      ExecStart: /app/sol/kafka/confluent/confluent-control-center-next-gen-2.5.0/bin/prometheus-start
      TSDB_PATH: /data01/sol/kafka/confluent/prometheus/data
      LOG_PATH: /log/sol/kafka/confluent/prometheus
      METRICS_RETENTION_DAYS: "15d"

    control_center_next_gen_dependency_alertmanager_service_environment_overrides:
      User: 1726_admin1
      Group: 1726_admin1
      ALERTMANAGER_HOST: kiju-cp-test-4.fgcp-integration.com
      ALERTMANAGER_PORT: 9098
      ExecStart: /app/sol/kafka/confluent/confluent-control-center-next-gen-2.5.0/bin/alertmanager-start
      STORAGE_PATH: /data01/sol/kafka/confluent/alertmanager/data
      LOG_PATH: /log/sol/kafka/confluent/alertmanager
      WEB_LISTEN_ADDRESS: "0.0.0.0:9098"
      CONTROL_CENTER_ALERTMANAGER_HA_ENABLED: false
      CLUSTER_ADVERTISE_ADDRESS: "0.0.0.0:9098"

    schema_registry_service_environment_overrides:
      SCHEMA_REGISTRY_HEAP_OPTS: "-Xms8G -Xmx8G"
        #SCHEMA_REGISTRY_OPTS: " -javaagent:/app/sol/kafka/confluent/etc/jmx_prometheus_javaagent-0.20.0.jar=9997:/app/sol/kafka/confluent/etc/client.yml"

kafka_controller:
  vars:
    #secrets_protection_enabled: false
  hosts:
    kiju-cp-test-1.fgcp-integration.com:
      node_id: 9991
      node_ip: 192.168.20.246
    kiju-cp-test-2.fgcp-integration.com:
      node_id: 9992
      node_ip: 192.168.20.247
    kiju-cp-test-3.fgcp-integration.com:
      node_id: 9993
      node_ip: 192.168.20.248

kafka_broker:
  vars:
    #secrets_protection_enabled: false
  hosts:
    kiju-cp-test-1.fgcp-integration.com:
      broker_id: 1
      broker_ip: 192.168.20.246
     
    kiju-cp-test-2.fgcp-integration.com:
      broker_id: 2
      broker_ip: 192.168.20.247
        
    kiju-cp-test-3.fgcp-integration.com:
      broker_id: 3
      broker_ip: 192.168.20.248
        
control_center_next_gen:
  vars:
    ssl_provided_keystore_and_truststore: false
    ssl_provided_keystore_and_truststore_remote_src: false
    ssl_keystore_and_truststore_custom_password: true
    ssl_keystore_store_password: "{{ c3_ssl_keystore_password }}"
    ssl_keystore_key_password: "{{ c3_ssl_key_password }}"
    ssl_truststore_password: "{{ c3_ssl_truststore_password }}"
    control_center_next_gen_ldap_user: "{{ c3_service_user }}"
    control_center_next_gen_ldap_password: "{{ c3_service_password }}"

  hosts:
    kiju-cp-test-4.fgcp-integration.com:
      control_center_next_gen_custom_properties:
        confluent.controlcenter.id: 3
        confluent.controlcenter.prometheus.url: http://kiju-cp-test-4.fgcp-integration.com:9090
        confluent.controlcenter.alertmanager.url: http://kiju-cp-test-4.fgcp-integration.com:9098

        confluent.controlcenter.internal.topics.replication: 3
        confluent.controlcenter.command.topic.replication: 3
        confluent.controlcenter.ui.autoupdate.enable: false
        confluent.controlcenter.usage.data.collection.enable: true
        confluent.controlcenter.ksql.enable: false
        confluent.controlcenter.schema.registry.enable: true
        confluent.controlcenter.schema.registry.url: "http://kiju-cp-test-1.fgcp-integration.com:9081,http://kiju-cp-test-2.fgcp-integration.com:9081"
        confluent.controlcenter.rest.listeners: "https://kiju-cp-test-4.fgcp-integration.com:9021"

        # Control Center REST auth mode (user login handled by OIDC below)
        confluent.controlcenter.rest.authentication.method: BEARER
        confluent.controlcenter.auth.sso.mode: OIDC
        confluent.controlcenter.auth.session.expiration.ms: 86400000

        # Control Center -> MDS (RBAC metadata access)
        confluent.metadata.bootstrap.server.urls: "http://kiju-cp-test-1.fgcp-integration.com:8090,http://kiju-cp-test-2.fgcp-integration.com:8090,http://kiju-cp-test-3.fgcp-integration.com:8090"
        confluent.metadata.basic.auth.user.info: "{{ c3_service_user }}:{{ c3_service_password }}"
        confluent.metadata.http.auth.credentials.provider: BASIC

        # Control Center -> Kafka (streams + monitoring interceptor clients)
        confluent.controlcenter.streams.sasl.jaas.config: org.apache.kafka.common.security.oauthbearer.OAuthBearerLoginModule required username="{{ c3_service_user }}" password="{{ c3_service_password }}" metadataServerUrls="http://kiju-cp-test-1.fgcp-integration.com:8090,http://kiju-cp-test-2.fgcp-integration.com:8090,http://kiju-cp-test-3.fgcp-integration.com:8090";
        confluent.monitoring.interceptor.sasl.jaas.config: org.apache.kafka.common.security.oauthbearer.OAuthBearerLoginModule required username="{{ c3_service_user }}" password="{{ c3_service_password }}" metadataServerUrls="http://kiju-cp-test-1.fgcp-integration.com:8090,http://kiju-cp-test-2.fgcp-integration.com:8090,http://kiju-cp-test-3.fgcp-integration.com:8090";

        # Control Center -> Schema Registry
        confluent.controlcenter.schema.registry.basic.auth.credentials.source: USER_INFO
        confluent.controlcenter.schema.registry.basic.auth.user.info: "{{ c3_service_user }}:{{ c3_service_password }}"

        # External user -> Control Center (OIDC login against Authentik)
        confluent.oidc.idp.client.id: "6A3rZBHmDQ3Xp6CqyoV4yWsRMHFxF230dW7J2RQR"
        confluent.oidc.idp.client.secret: "lNIIfyoWf0GNopEEITkKboxRVdNVXlEcn6NtlZDgKbY1VdJ0kpEY85e1gmufmpfJlUD3IkMnIsxoTQlpRsnJ7pUsdxTqGcEeJASnshcoymCDkDJCNqu7p3lQqRjQ9s0Q"
        confluent.oidc.idp.issuer: "https://kiju-cp-test-4.fgcp-integration.com:9000/"
        confluent.oidc.idp.jwks.endpoint.uri: "https://kiju-cp-test-4.fgcp-integration.com:9000/application/o/confluent-control-center/jwks/"
        confluent.oidc.idp.authorize.base.endpoint.uri: "https://kiju-cp-test-4.fgcp-integration.com:9000/application/o/authorize/"
        confluent.oidc.idp.token.base.endpoint.uri: "https://kiju-cp-test-4.fgcp-integration.com:9000/application/o/token/"
        confluent.oidc.idp.sub.claim.name: preferred_username
        confluent.oidc.idp.groups.claim.name: groups
        confluent.oidc.idp.groups.claim.scope: "openid profile email"
        confluent.oidc.idp.refresh.token.enabled: "true"
        confluent.oidc.session.token.expiry.ms: 86400000
        confluent.oidc.session.max.timeout.ms: 86400000

