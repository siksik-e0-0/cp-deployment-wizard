      ansible_host: 192.168.20.246
      schema_registry_host_name: kiju-cp-test-1.fgcp-integration.com
      schema_registry_listener_hostname: kiju-cp-test-1.fgcp-integration.com

    kiju-cp-test-2.fgcp-integration.com:
